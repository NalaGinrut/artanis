(define-module (test hash)
  #:use-module (artanis utils)
  #:use-module (ice-9 iconv)
  #:use-module (test-suite lib))

;; export all things, since we need to test inner cookie
(eval-when (eval load compile)
  (export-all-from-module! '(artanis security nss))
  (export-all-from-module! '(artanis security hash)))

(with-test-prefix "Hash test"

  #;
  (pass-if "sha-224"                    ; ;
  (string=? "ea09ae9cc6768c50fcee903ed054556e5bfc8347907f12598aa24193 ; ;
  "                                     ; ;
  (nss:sha-224 "hello")))

  (pass-if "sha-256"
    (string=? "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"
              (string->sha-256 "hello")))

  (pass-if "sha-384"
    (string=? "59e1748777448c69de6b800d7a33bbfb9ff1b463e44354c3553bcdb9c666fa90125a3c79f90397bdf5f6a13de828684f"
              (string->sha-384 "hello")))

  (pass-if "sha-512"
    (string=? "9b71d224bd62f3785d96d46ad3ea3d73319bfbc2890caadae2dff72519673ca72323c3d99ba5c11d7c7acc6e14b8c5da0c4663475c2e5c3adef46f73bcdec043"
              (string->sha-512 "hello")))

  (pass-if "md5"
    (string=? "5d41402abc4b2a76b9719d911017c592"
              (string->md5 "hello")))

  (pass-if "sha-1"
    (string=? "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d"
              (string->sha-1 "hello")))

  (pass-if "base64"
    (string=? "hello"
              (nss:base64-decode (nss:base64-encode "hello"))))

  ;; test base16
  (pass-if "base16"
    (string=? "hello"
              (base16-decode (base16-encode "hello"))))

  ;; test base32
  (pass-if "base32"
    (string=? "hello"
              (base32-decode (base32-encode "hello"))))

  (define test-key "a-random-salt")
  (define test-data "The quick brown fox jumps over the lazy dog")

  ;; HMAC tests — key/data from RFC 4231 / well-known vectors
  (pass-if "hmac-md5"
    (string=? "a8c3829ddb8fd852d56678067586fdd2"
              (string->hmac-md5 test-key test-data)))

  (pass-if "hmac-sha-1"
    (string=? "b2c349f9e9042b728434cfb54b2b778140c928c2"
              (string->hmac-sha-1 test-key test-data)))

  #;
  (pass-if "hmac-sha-224"               ;
  (string=? "c7aaaddeb5599b299aa6b434590f208ff6a2254b4c79de1f2634e86a" ;
  (string->hmac-sha-224 test-key test-data)))

  (pass-if "hmac-sha-256"
    (string=? "a6a67c6106705fe3abf8310a8f5f0fc12121848cc1a25fc10919991482086126"
              (string->hmac-sha-256 test-key test-data)))
  (pass-if "hmac-sha-384"
    (string=? "3fc78c25dc495dfda3e906f95d519b25a46d8c693ed5f1eed21467056ce99c0cb026f2eb0f8c90079a48d70f2292db49"
              (string->hmac-sha-384 test-key test-data)))
  (pass-if "hmac-sha-512"
    (string=? "e136a1b22d8f7f8ff868c346fe053aab1b22e6ba7794a614dac231a1aee6754b2be18adfa821ad45e0beb89bb4eb706263c497e38692359039101c630ce91082"
              (string->hmac-sha-512 test-key test-data)))

  ;; Verify bytevector input works the same as string input
  (pass-if "hmac-sha-256 bytevector input"
    (string=? (string->hmac-sha-256 test-key test-data)
              (string->hmac-sha-256
               (string->bytevector test-key "iso-8859-1")
               (string->bytevector test-data "iso-8859-1"))))

  ;; Verify different keys produce different output (sanity check)
  (pass-if "hmac-sha-256 key sensitivity"
    (not (string=? (string->hmac-sha-256 "key1" "hello")
                   (string->hmac-sha-256 "key2" "hello"))))
  )
